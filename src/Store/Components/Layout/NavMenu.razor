@using Store.Components.Cart

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="32" height="32" rx="8" fill="#6366f1"/>
                <text x="16" y="22" text-anchor="middle" fill="white" font-size="18" font-weight="800" font-family="Inter, sans-serif">Z</text>
            </svg>
            Zava Store
        </a>
        <div class="ms-auto">
            <CartIcon OnToggleCart="ToggleCart" />
        </div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span>Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="products">
                <span class="bi bi-list-nested" aria-hidden="true"></span>Products
            </NavLink>
        </div>

        <!-- Smart Search Option -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="search">
                <span class="bi bi-search" aria-hidden="true"></span>Search
            </NavLink>
        </div>

        <!-- Cart Option -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="cart">
                <span class="bi bi-cart" aria-hidden="true"></span>Cart
            </NavLink>
        </div>

        <!-- Settings Option -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="settings">
                <span class="bi bi-gear" aria-hidden="true"></span>Settings
            </NavLink>
        </div>

        <!-- Database Viewer Option -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="data">
                <span class="bi bi-database" aria-hidden="true"></span>Database
            </NavLink>
        </div>

        <!-- Agent Demo Section -->
        <div class="nav-section-divider"></div>
        <div class="nav-item px-3">
            <span class="nav-section-label">Agent Demos</span>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="scenario1-single-agent">
                <span class="bi bi-robot" aria-hidden="true"></span>Single Agent
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="scenario2-multi-agent">
                <span class="bi bi-people" aria-hidden="true"></span>Multi-Agent
            </NavLink>
        </div>

        <div class="nav-section-divider"></div>
        <div class="nav-item px-3">
            <span class="nav-section-label">DevUI Tools</span>
        </div>

        <div class="nav-item px-3">
            <a class="nav-link" href="/api/devui/singleagent" target="_blank" rel="noopener noreferrer">
                <span class="bi bi-code-slash" aria-hidden="true"></span>Single Agent DevUI
            </a>
        </div>

        <div class="nav-item px-3">
            <a class="nav-link" href="/api/devui/multiagent" target="_blank" rel="noopener noreferrer">
                <span class="bi bi-code-slash" aria-hidden="true"></span>Multi-Agent DevUI
            </a>
        </div>
    </nav>
</div>

@code {
    [Parameter] public EventCallback OnToggleCart { get; set; }

    private async Task ToggleCart()
    {
        await OnToggleCart.InvokeAsync();
    }
}